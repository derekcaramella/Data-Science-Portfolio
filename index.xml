    <item>
      <title>About</title>
      <link>https://derekcaramella.github.io/Data-Science-Portfolio/about/</link>
      <pubDate>Fri, 28 Feb 2020 00:00:00 +0000</pubDate>
      
      <guid>https://derekcaramella.github.io/Data-Science-Portfolio/about/</guid>
      <description>&lt;style&gt;
body { 
    margin: 2px 2px 2px 2px; 
    text-align: center;
} 
h1 { 
    color: green; 
} 
